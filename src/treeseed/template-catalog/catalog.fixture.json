        "url": "https://treeseed.ai"
      },
      "publisherVerified": true,
      "templateVersion": "0.1.0",
      "templateApiVersion": 1,
      "minCliVersion": "0.1.1",
      "minCoreVersion": "0.1.2",
      "fulfillment": {
